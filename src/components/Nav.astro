---
const pathname = new URL(Astro.request.url).pathname;
const link = (href: string) =>
  `transition hover:text-amber-brand ${pathname === href ? 'text-amber-brand' : ''}`;
---

<header class="fixed top-0 left-0 right-0 z-40 backdrop-blur-md bg-espresso/60 dark:bg-espresso/60 supports-[backdrop-filter]:bg-espresso/40">
  <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="font-display text-2xl md:text-[1.75rem] tracking-tight">Meridian</span>
      <span class="block w-1.5 h-1.5 rounded-full bg-amber-brand transition group-hover:scale-125"></span>
    </a>

    <nav class="hidden md:flex items-center gap-10 text-[0.85rem] tracking-[0.14em] uppercase">
      <a href="/" class={link('/')}>Home</a>
      <a href="/about" class={link('/about')}>Our Story</a>
      <a href="/#ritual" class="transition hover:text-amber-brand">The Ritual</a>
      <a href="/#waitlist" class="transition hover:text-amber-brand">Waitlist</a>
    </nav>

    <div class="flex items-center gap-3">
      <button
        aria-label="Toggle theme"
        onclick="window.__toggleTheme && window.__toggleTheme()"
        class="w-9 h-9 rounded-full border border-cream/15 flex items-center justify-center hover:border-amber-brand/60 transition"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path></svg>
      </button>
      <a
        href="/#waitlist"
        class="hidden md:inline-flex items-center gap-2 text-[0.82rem] tracking-[0.18em] uppercase border border-amber-brand/50 text-amber-brand hover:bg-amber-brand hover:text-espresso transition px-4 py-2 rounded-full"
      >
        Join Waitlist
      </a>
    </div>
  </div>
</header>
