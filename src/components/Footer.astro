---
const year = new Date().getFullYear();
---

<footer class="border-t border-cream/10 mt-24">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-12 md:py-16 grid md:grid-cols-3 gap-10">
    <div>
      <a href="/" class="inline-flex items-center gap-2">
        <span class="font-display text-3xl tracking-tight">Meridian</span>
        <span class="block w-1.5 h-1.5 rounded-full bg-amber-brand"></span>
      </a>
      <p class="mt-4 text-sm max-w-xs opacity-70 leading-relaxed">
        A specialty coffee brand for the intentional drinker. Single-origin roasts and curated blends, launching soon.
      </p>
    </div>

    <div>
      <h4 class="text-[0.78rem] tracking-[0.18em] uppercase opacity-60 mb-4">Explore</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/" class="hover:text-amber-brand transition">Home</a></li>
        <li><a href="/about" class="hover:text-amber-brand transition">Our Story</a></li>
        <li><a href="/#ritual" class="hover:text-amber-brand transition">The Ritual</a></li>
        <li><a href="/#waitlist" class="hover:text-amber-brand transition">Join the Waitlist</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-[0.78rem] tracking-[0.18em] uppercase opacity-60 mb-4">Stay Close</h4>
      <p class="text-sm opacity-70 mb-4 leading-relaxed">
        Early access, farm-gate stories, and launch-day allocations land in your inbox first.
      </p>
      <a
        href="/#waitlist"
        class="inline-flex items-center gap-2 text-[0.78rem] tracking-[0.18em] uppercase text-amber-brand hover:text-amber-brand-hover transition"
      >
        Reserve your place
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <div class="border-t border-cream/10">
    <div class="max-w-6xl mx-auto px-6 md:px-10 py-6 flex flex-col md:flex-row items-center justify-between text-xs opacity-60 gap-2">
      <p>© {year} Meridian Coffee Co. All rights reserved.</p>
      <p class="tracking-[0.18em] uppercase">Roasted with intent · Shared with purpose</p>
    </div>
  </div>
</footer>
