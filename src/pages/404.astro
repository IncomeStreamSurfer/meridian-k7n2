---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Page not found — Meridian" description="We couldn't find that page." noindex>
  <Nav />
  <section class="min-h-[70svh] flex items-center">
    <div class="max-w-3xl mx-auto px-6 md:px-10 text-center pt-32">
      <div class="text-[0.78rem] tracking-[0.28em] uppercase opacity-60 mb-6">
        Error 404
      </div>
      <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.05] tracking-tight">
        That page is<br />
        <span class="italic text-amber-brand">off the map.</span>
      </h1>
      <p class="mt-6 opacity-75 max-w-lg mx-auto">
        The link you followed points to a page that doesn't exist yet — or
        never will. Let's get you back to what's brewing.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center gap-2 bg-amber-brand hover:bg-amber-brand-hover text-espresso font-medium text-[0.82rem] tracking-[0.18em] uppercase px-6 py-3.5 rounded-full transition">
          Back home
        </a>
        <a href="/about" class="inline-flex items-center gap-2 text-[0.82rem] tracking-[0.18em] uppercase border border-cream/20 hover:border-amber-brand hover:text-amber-brand transition px-6 py-3.5 rounded-full">
          Read our story
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Base>
